{
  "schema_version": 2,
  "id": "doupo-game",
  "name": "斗破文字游戏",
  "version": "0.6.0",
  "description": "斗破题材互动养成：路线游历、聚气操作、宗门、拍卖、丹药、异火、斗技与塔修",
  "entry": "plugin",
  "enabled": true,
  "plugin_type": "builtin",
  "requires_restart": false,
  "permissions": [
    "telegram.commands",
    "telegram.callback_query",
    "telegram.read_group_messages",
    "telegram.read_private_messages",
    "telegram.send_group_messages",
    "telegram.send_private_messages",
    "web.routes",
    "web.static",
    "database.shared_read",
    "database.shared_write"
  ],
  "dependencies": {
    "python": []
  },
  "database": {
    "migrations_dir": "migrations"
  },
  "miniapp": {
    "path": "/plugins/doupo/app",
    "admin_path": "/plugins/doupo/admin",
    "label": "斗破",
    "icon": "🔥",
    "bottom_nav_default": true
  }
}
